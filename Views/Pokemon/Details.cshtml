@model ActividadAutonoma_as.Models.Pokemon

<div class="container my-4">
    <h1 class="text-capitalize text-center">#@Model.Id - @Model.Name</h1>

    <div class="row mt-4">


        <div class="col-md-12">
            <table class="table table-bordered">
                <tr><th>Altura</th><td>@(Model.Height / 10.0) m</td></tr>
                <tr><th>Peso</th><td>@(Model.Weight / 10.0) kg</td></tr>
                <tr><th>Experiencia Base</th><td>@Model.BaseExperience</td></tr>
                <tr>
                    <th>Tipos</th>
                    <td>
                        @foreach (var tipos in Model.Types)
                        {
                            <span class="badge bg-success text-capitalize">@tipos.Type.Name</span>
                        }
                    </td>
                </tr>
                <tr>
                    <th>Habilidades</th>
                    <td>
                        @foreach (var habilidades in Model.Abilities)
                        {
                            <span class="badge bg-@(habilidades.IsHidden ? "secondary" : "primary") text-capitalize">
                                @habilidades.Ability.Name @(habilidades.IsHidden ? "(oculta)" : "")
                            </span>
                        }
                    </td>
                </tr>
            </table>

            <h5>Estadísticas base</h5>
            <table class="table table-bordered table-sm">
                @foreach (var stados in Model.Stats)
                {
                    <tr>
                        <th class="text-capitalize">@stados.Stat.Name</th>
                        <td>@stados.BaseStat</td>
                    </tr>
                }
            </table>

            <h5 class="mt-3">Movimientos (@Model.Moves.Count)</h5>
            <div class="d-flex flex-wrap gap-1">
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var movimientos in Model.Moves)
                    {
                        <span class="badge bg-info text-dark text-capitalize">@movimientos.Move.Name</span>
                    }
                </div>

            </div>
        </div>
    </div>


    <h5 class="mt-4">Sprites</h5>
    <div class="row g-3 justify-content-center">

        <div class="col-6 col-md-3 text-center">
            <div class="card p-2 h-100">
                <div style="height:150px; display:flex; align-items:center; justify-content:center;">
                    <img src="@Model.Sprites.FrontDefault"
                         alt="@Model.Name - Sprite de frente Normal"
                         style="height:200px; width: fit-content; margin:10px;  object-fit:contain">
                </div>
                <small class="mt-1 text-capitalize">@Model.Name - Normal</small>
            </div>
        </div>
        <div class="col-6 col-md-3 text-center">
            <div class="card p-2 h-100">
                <div style="height:150px; display:flex; align-items:center; justify-content:center;">
                    <img src="@Model.Sprites.FrontShiny"
                         alt="@Model.Name - Sprite de frente Shiny"
                         style="height:200px; width: fit-content; margin:10px;  object-fit:contain">
                </div>
                <small class="mt-1 text-capitalize">@Model.Name - Shiny</small>
            </div>
        </div>
        <div class="col-6 col-md-3 text-center">
            <div class="card p-2 h-100">
                <div style="height:150px; display:flex; align-items:center; justify-content:center;">
                    <img src="@Model.Sprites.BackDefault"
                         alt="@Model.Name - Sprite desde atrás"
                         style="height:200px; width: fit-content; margin:10px;   object-fit:contain">
                </div>
                <small class="mt-1 text-capitalize">@Model.Name - Trasero</small>
            </div>
        </div>
        <div class="col-6 col-md-3 text-center">
            <div class="card p-2 h-100">
                <div style="height:150px; display:flex; align-items:center; justify-content:center;">
                    <img src="@Model.Sprites.BackShiny"
                         alt="@Model.Name - Sprite desde atrás Shiny"
                         style="height:200px; width: fit-content; margin:10px;   object-fit:contain">
                </div>
                <small class="mt-1 text-capitalize">@Model.Name - Trasero Shiny</small>
            </div>
        </div>

    </div>






    <div class="text-center mt-4">
        <a asp-controller="Pokemon" asp-action="Index" class="btn btn-primary">Volver a la lista</a>
    </div>

</div>
