@model ActividadAutonoma_as.Models.PokemonIndexViewModel

<div class="container text-center">
    <h1 class="my-4">Pokédex</h1>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var p in Model.Pokemons)
        {
            <div class="col">
                <div class="card h-100">
                    <img src="@p.SpriteUrl"
                         class="card-img-top p-2 mx-auto"
                         alt="@p.Name"
                         style="height:200px; object-fit:contain; width:auto">
                    <div class="card-body">
                        <h6 class="card-title text-capitalize">#@p.Id - @p.Name</h6>
                        <a class="btn btn-sm btn-primary"
                           asp-controller="Pokemon"
                           asp-action="Details"
                           asp-route-id="@p.Name">Ver Detalles</a>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="mt-4 d-flex justify-content-center gap-3">
        @if (Model.Offset > 0)
        {
            <a class="btn btn-secondary"
               asp-controller="Pokemon" asp-action="Index"
               asp-route-offset="@(Model.Offset - Model.Limit)"
               asp-route-limit="@Model.Limit">Anterior</a>
        }
        @if (Model.Offset + Model.Limit < Model.Total)
        {
            <a class="btn btn-secondary"
               asp-controller="Pokemon" asp-action="Index"
               asp-route-offset="@(Model.Offset + Model.Limit)"
               asp-route-limit="@Model.Limit">Siguiente</a>
        }
    </div>
</div>
